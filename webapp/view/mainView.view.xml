<mvc:View
    controllerName="empms.controller.mainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:unified="sap.ui.unified"
>
    <Page
        id="page"
        title="{i18n>title}"
    >
        <headerContent>
            <Button
                text="Add Product"
                type="Emphasized"
                press=".onAddProduct"
            />
        </headerContent>

        <content>
            <VBox class="sapUiSmallMarginBegin sapUiMediumMarginTop">
                <Title text="Welcome to Product Management System"
                        level= "H2"
                        class="welcomeHeading"  />
            </VBox>

            <!-- KPI Tiles -->

            <HBox
                justifyContent="Start"
                class="sapUiMediumMarginTop sapUiMediumMarginBegin sapUiMediumMarginEnd"
                width="100%"
                renderType="Bare"
            >
            <HBox
                class="sapUiLargeMarginTop ">   
                <GenericTile
                    class="sapUiSmallMarginEnd"
                    header="Total Products"
                    frameType="OneByOne"
                    
                    
                >
                    <TileContent footer="Across Warehouse">
                        <NumericContent
                            value="{local>/kpi/totalProducts}"
                            scale=""
                            icon = "sap-icon://list"
                        />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    class="sapUiSmallMarginEnd"
                    header="Inventory Value"
                    frameType="OneByOne"
                    pressEnabled="false"
                    
                >
                    <TileContent footer="Across Warehouse">
                        <NumericContent
                            value="{local>/kpi/totalValue}"
                            scale=""
                            icon="sap-icon://sum"
                        />
                    </TileContent>
                </GenericTile>
    
                <GenericTile
                    class="sapUiSmallMarginEnd"
                    header="Low Stocks"
                    frameType="OneByOne"
                    press=".onLowStockPress"
                >
                    <TileContent footer="Stocks Less than 10">
                        <NumericContent
                            value="{local>/kpi/lowStock}"
                            scale=""
                             icon="sap-icon://trend-down"
                        />
                    </TileContent>
                </GenericTile>

                <GenericTile
                    class="sapUiSmallMarginEnd"
                    header="Discontinued"
                    frameType="OneByOne"
                    press=".onDiscontinuedPress"
                >
                    <TileContent footer="Across Warehouse">
                        <NumericContent
                            value="{local>/kpi/discontinued}"
                            scale=""
                            icon="sap-icon://cancel"
                        />
                    </TileContent>
                </GenericTile>

                </HBox>

                <!-- chart -->
                <VBox alignItems="Center">
                    <Select
                        change="onChartTypeChange"
                        class="sapUiSmallMarginBottom"
                        width="100px"
                    >
                        <items>
                            <core:Item
                                key="column"
                                text="Column"
                            />
                            <core:Item
                                key="bar"
                                text="Bar"
                            />
                            <core:Item
                                key="line"
                                text="Line"
                            />
                            <core:Item
                                key="pie"
                                text="Pie"
                            />
                        </items>
                    </Select>

                    <viz:VizFrame
                        id="idVizFrame"
                        vizType="line"
                        width="700px"
                        height="200px"
                    >
                        <viz:dataset>
                            <viz.data:FlattenedDataset data="{local>/Products}">
                                <viz.data:dimensions>
                                    <viz.data:DimensionDefinition
                                        name="Product"
                                        value="{local>ProductName}"
                                    />
                                </viz.data:dimensions>

                                <viz.data:measures>
                                    <viz.data:MeasureDefinition
                                        name="Price"
                                        value="{local>UnitPrice}"
                                    />
                                </viz.data:measures>
                            </viz.data:FlattenedDataset>
                        </viz:dataset>

                        <viz:feeds>
                            <viz.feeds:FeedItem
                                uid="valueAxis"
                                type="Measure"
                                values="Price"
                            />
                            <viz.feeds:FeedItem
                                uid="categoryAxis"
                                type="Dimension"
                                values="Product"
                            />
                        </viz:feeds>
                    </viz:VizFrame>
                </VBox>
            </HBox>

            <!-- Search + Filter + Sort Toolbar -->
            <Toolbar class="sapUiMediumMarginTop">
                <SearchField
                    id="idSearchField"
                    placeholder="Search by name..."
                    width="300px"
                    liveChange=".onSearch"
                />

                <ToolbarSpacer />

                <Select
                    id="idDiscontinuedFilter"
                    change=".onFilter"
                >
                    <items>
                        <core:Item
                            key="ALL"
                            text="All Status"
                        />
                        <core:Item
                            key="true"
                            text="Discontinued"
                        />
                        <core:Item
                            key="false"
                            text="Active"
                        />
                        <!-- <core:Item
                            key="Finance"
                            text="Finance"
                        />
                        <core:Item
                            key="Design"
                            text="Design"
                        />
                        <core:Item
                            key="Sales"
                            text="Sales"
                        />
                        <core:Item
                            key="Marketing"
                            text="Marketing"
                        /> -->
                    </items>
                </Select>

                <Select
                    id="idSort"
                    change=".onSort"
                >
                    <items>
                        <core:Item
                            key="none"
                            text="Sort By"
                        />
                        <core:Item
                            key="nameAsc"
                            text="Name A→Z"
                        />
                        <core:Item
                            key="nameDesc"
                            text="Name Z→A"
                        />
                        <core:Item
                            key="PriceAsc"
                            text="Unit Price Low→High"
                        />
                        <core:Item
                            key="PriceDesc"
                            text="Unit Price High→Low"
                        />
                    </items>
                </Select>
            </Toolbar>

            <Table
                id="ProductTable"
                items="{
                path : 'local>/Products',
                length : 10
                }"
                mode="MultiSelect"
                growing="true"
                growingThreshold="10"
                growingScrollToLoad="true"
            >
                <headerToolbar>
                    <Toolbar>
                        <Title text="Product Table" />
                        <ToolbarSpacer />
                        <Button
                            icon="sap-icon://sort"
                            text="Sort"
                            press="onOpenSortDialog"
                        />

                        <!-- <Label text="Import from Excel:" /> -->
                        <!-- <unified:FileUploader
                            id="idfileUploader"
                            fileType="xlsx,xls"
                            change="onFileUpload"
                            buttonText="Upload Excel"
                            buttonOnly="true"
                            iconOnly="false"
                            style="Default"
                        />

                        <Button
                            text="Download Template"
                            icon="sap-icon://download"
                            type="Transparent"
                            press="onDownloadTemplate"
                        /> -->
                        <Button
                            text="Mass Edit"
                            icon="sap-icon://edit"
                            press="onMassEditPress"
                            />

                         <Button
                            text="Upload Excel"
                            icon="sap-icon://upload"
                            type="Transparent"
                            press="onImportPress"
                        />

                        <Button
                            text="Export Selected"
                            icon="sap-icon://download"
                            press="onExportSelected"
                            type="Emphasized"
                        />
                    </Toolbar>
                </headerToolbar>
                <MessageStrip
                    id="uploadResultStrip"
                    text=""
                    type="Success"
                    showCloseButton="true"
                    visible="false"
                    class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop"
                    close="onCloseUploadStrip"
                />

                <columns>
                    <Column>
                        <Text text="Product ID" />
                    </Column>
                    <Column>
                        <Text text="Product Name" />
                    </Column>
                    <Column>
                        <Text text="Unit Price" />
                    </Column>
                    <Column>
                        <Text text="Units In Stock" />
                    </Column>
                    <Column>
                        <Text text="Discontinued" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem
                        type="Navigation"
                        press=".onEmployeePress"
                    >
                        <cells>
                            <Text text="{local>ProductID}" />
                            <Text text="{local>ProductName}" />
                            <Text text="{local>UnitPrice}" />
                            <Text text="{local>UnitsInStock}" />
                            <!-- <Text text="{local>Discontinued}" /> -->
                            <!-- <Text text="{= ${local>Discontinued} ? 'Discontinued' : 'Active' }" /> -->
                            <ObjectStatus
                                text="{= ${local>Discontinued} ? 'Discontinued' : 'Active' }"
                                state="{= ${local>Discontinued} ? 'Error' : 'Success' }"
                            />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
