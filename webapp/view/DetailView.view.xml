<mvc:View
    controllerName="empms.controller.DetailView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
>
    <Page
        title="Product Detail"
        showNavButton="true"
        navButtonPress=".onBack"
    >
        <headerContent>
            <Button
                text="Edit"
                type="Emphasized"
                icon="sap-icon://edit"
                press=".onEdit"
                visible="{= !${ui>/editMode} }"
            />
            <!-- <Button
                text="Save"
                type="Accept"
                press=".onSave"
                visible="{= ${/editMode} }"/>
            <Button
                text="Cancel"
                type="Reject"
                press=".onCancel"
                visible="{= ${/editMode} }"/> -->
        </headerContent>

        <content>
        <Panel
                class="sapUiResponsiveMargin"
                backgroundDesign="Solid"
            >

            <content>
                    <VBox
                        alignItems="Center"
                        justifyContent="Center"
                        class="sapUiMediumMarginTop sapUiMediumMarginBottom sapUiMediumMarginBeginEnd"
                        wrap="Wrap"
                    >

            <!-- Avatar + Name + Role -->
                <Avatar
                    initials="{initials}"
                    displaySize="L"
                    backgroundColor="Accent5"
                     class="sapUiMediumMarginEnd"
                />
            <VBox justifyContent="Center" class="sapUiSmallMarginEnd" renderType="Bare">
                
                <Title
                    text="{local>ProductName}"
                    level="H2"
                     wrapping="true"
                    class="sapUiSmallMarginTop"
                />
                <!-- <Text
                    text="{UnitPrice}"
                    class="sapUiTinyMarginTop"
                /> -->
                <ObjectNumber
                    number="{local>UnitPrice}"
                    unit="USD"
                    emphasized="true"
                    class="sapUiTinyMarginTop"
                />
            </VBox>
                 </VBox>
                </content>
            </Panel>

             <Panel
                headerText="Product Details"
                expandable="false"
                class="sapUiResponsiveMargin"
                backgroundDesign="Solid"
            >
            <content>
                <form:SimpleForm
                    editable="false"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="4"
                        labelSpanL="4"
                        labelSpanM="4"
                        labelSpanS="12"
                        emptySpanXL="0"
                        emptySpanL="0"
                        emptySpanM="0"
                        columnsXL="2"
                        columnsL="2"
                        columnsM="1"
                        class="sapUiSmallMarginTop sapUiSmallMarginBottom"
                >
                    <form:content>
                        <Label text="Product ID" />
                        <VBox renderType="Bare" >
                            <Text
                                text="{local>ProductID}"
                                visible="{= !${ui>/editMode} }"
                            />
                            <Input
                                id="idProductID"
                                value="{local>ProductID}"
                                visible="{= ${ui>/editMode} }"
                                enabled= "false"
                                placeholder="Enter ID"
                                width="25%"
                            />
                        </VBox>

                        <Label text="Product Name" />
                        <VBox renderType="Bare" >
                            <Text
                                text="{local>ProductName}"
                                visible="{= !${ui>/editMode} }"
                            />
                            <Input
                                id="idProductName"
                                value="{local>ProductName}"
                                visible="{= ${ui>/editMode} }"
                                placeholder="Enter Name"
                                width="25%"
                            />
                        </VBox>

                        <Label text="Unit Price" />
                        <VBox renderType="Bare" >
                            <Text
                                text="{local>UnitPrice}"
                                visible="{= !${ui>/editMode} }"
                            />
                            <Input
                                id="idUnitPrice"
                                value="{local>UnitPrice}"
                                visible="{= ${ui>/editMode} }"
                                placeholder="Enter Department"
                                width="25%"
                            />
                        </VBox>

                        <Label text="Units In Stock" />
                        <VBox renderType="Bare" >
                            <Text
                                text="{local>UnitsInStock}"
                                visible="{= !${ui>/editMode} }"
                            />
                            <Input
                                id="idUnitsInStock"
                                value="{local>UnitsInStock}"
                                visible="{= ${ui>/editMode} }"
                                placeholder="Enter Role"
                                width="25%"
                            />
                        </VBox>

                        <Label text="Units On Order" />
                        <VBox renderType="Bare" >
                            <Text
                                text="{local>UnitsOnOrder}"
                                visible="{= !${ui>/editMode} }"
                            />
                            <Input
                                id="idUnitsOnOrder"
                                value="{local>UnitsOnOrder}"
                                visible="{= ${ui>/editMode} }"
                                placeholder="Enter Salary"
                                width="25%"
                            />
                        </VBox>

                        <Label text="Discontinued" />
                        <VBox renderType="Bare" >
                            <Text
                                text="{= ${local>Discontinued} ? 'Discontinued' : 'Active' }"
                                visible="{= !${ui>/editMode} }"
                            />
                            <!-- <Input id="idDiscontinued" value="{local>Discontinued}" visible="{= ${ui>/editMode} }" placeholder="Enter Status"/> -->
                            <Select
                                id="idDiscontinued"
                                selectedKey="{local>Discontinued}"
                                visible="{= ${ui>/editMode} }"
                                width="25%"
                            >
                                <items>
                                    <core:Item
                                        key="true"
                                        text="Discontinued"
                                    />
                                    <core:Item
                                        key="false"
                                        text="Active"
                                    />
                                </items>
                            </Select>
                        </VBox>
                    </form:content>
                </form:SimpleForm>
                </content>
            </Panel>

            <!-- Action Buttons -->
            <HBox
                justifyContent="Center"
                class="sapUiMediumMarginTop sapUiMediumMarginBottom"
            >
                <Button
                    text="Edit"
                    type="Emphasized"
                     icon="sap-icon://edit"
                    press=".onEdit"
                    class="sapUiSmallMarginEnd"
                    visible="{= !${ui>/editMode} }"
                />
                <Button
                    text="Delete"
                    type="Reject"
                    icon="sap-icon://delete"
                    press=".onDelete"
                    visible="{= !${ui>/editMode} }"
                />
                <Button
                    text="Save"
                    type="Accept"
                    icon="sap-icon://save"
                    press=".onSave"
                    class="sapUiSmallMarginEnd"
                    visible="{= ${ui>/editMode} }"
                />
                <Button
                    text="Cancel"
                    type="Reject"
                     icon="sap-icon://cancel"
                    press=".onCancel"
                    visible="{= ${ui>/editMode} }"
                />
            </HBox>
        </content>
    </Page>
</mvc:View>
