<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Dialog
        title="Import Products"
        contentWidth="400px"
    >
        <content>
            <VBox class="sapUiMediumMargin">
                <Title text="Download Template" />
                <Button
                    text="Download Template"
                    icon="sap-icon://download"
                    type="Transparent"
                    press="onDownloadTemplate"
                />

                <Title
                    text="Upload Filled File"
                    class="sapUiLargeMarginTop"
                />
                <u:FileUploader
                    id="idfileUploader"
                    fileType="xlsx,xls"
                    change="onFileUpload"
                    buttonText="Upload Excel"
                    buttonOnly="true"
                    iconOnly="false"
                    style="Default"
                />

                <MessageStrip
                    text="Only .xlsx files are supported"
                    type="Information"
                    showIcon="true"
                    class="sapUiSmallMarginTop"
                />
            </VBox>
        </content>

        <endButton>
            <Button
                text="Cancel"
                press="onCancelImport"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
