<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
<Dialog
    title="Mass Edit Products"
    contentWidth="800px"
    resizable="true"
    draggable="true">

    <content>
        <Table
            id="massEditTable"
            items="{massEdit>/selectedItems}">

            <columns>
                <Column><Text text="Product ID" /></Column>
                <Column><Text text="Product Name" /></Column>
                <Column><Text text="Unit Price" /></Column>
                <Column><Text text="Units In Stock" /></Column>
                <Column><Text text="Status" /></Column>
            </columns>

            <items>
                <ColumnListItem>
                    <cells>
                        <!-- Read only — identifier -->
                        <Text text="{massEdit>ProductID}" />
                        <Text text="{massEdit>ProductName}" />

                        <!-- Editable fields -->
                        <Input value="{massEdit>UnitPrice}" type="Number" />
                        <Input value="{massEdit>UnitsInStock}" type="Number" />
                        <Select selectedKey="{massEdit>Status}">
                            <items>
                                <core:Item key="Active" text="Active" />
                                <core:Item key="Discontinued" text="Discontinued" />
                            </items>
                        </Select>
                    </cells>
                </ColumnListItem>
            </items>

        </Table>
    </content>

    <beginButton>
        <Button text="Save" type="Emphasized" press="onMassEditSave" />
    </beginButton>
    <endButton>
        <Button text="Cancel" press="onMassEditCancel" />
    </endButton>

</Dialog>
</core:FragmentDefinition>